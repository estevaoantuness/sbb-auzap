# ════════════════════════════════════════════════════════════════════════════
# SBB-AuZap — Dev local — template de envs
# ════════════════════════════════════════════════════════════════════════════
# Copiado automaticamente para .env.dev via scripts/bootstrap-dev.sh.
# Valores reais de OPENAI_API_KEY / WABA_* precisam ser editados após a cópia.
# .env.dev está no .gitignore.
# ════════════════════════════════════════════════════════════════════════════

# === DB (postgres local do docker-compose.dev.yml) ═══════════════════════
# Overridado pelo compose pra usar hostname interno (postgres:5432).
DATABASE_URL=postgresql://postgres:devlocal@localhost:5432/sbb?schema=public&connection_limit=10

# === WhatsApp — em dev padrão é Baileys (scan QR no celular de teste) ═════
WHATSAPP_PROVIDER=baileys
BAILEYS_SESSIONS_PATH=./.baileys-sessions-dev

# Se quiser testar Cloud API em dev (stubs — webhooks simulados via curl):
# WHATSAPP_PROVIDER=cloud_api
WABA_PHONE_NUMBER_ID=dev_stub_phone_id
WABA_BUSINESS_ACCOUNT_ID=dev_stub_business_account
WABA_ACCESS_TOKEN=dev_stub_access_token
WABA_APP_SECRET=dev_stub_app_secret_change_for_real_webhook_tests
WABA_VERIFY_TOKEN=dev_verify_token_local

# === OpenAI — em dev usar chave real só pra testes que consomem API ═════
# Pra desenvolvimento sem custo, deixe em branco e mock nos testes.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MODEL_SUMMARY=gpt-5.4-mini
OPENAI_MODEL_JUDGE=gpt-5.4
OPENAI_DAILY_BUDGET_USD=2      # budget baixo em dev
HISTORY_SUMMARY_ENABLED=true

# === Queue ════════════════════════════════════════════════════════════════
PGBOSS_POOL_MAX=3
INBOUND_CONCURRENCY=5
COALESCING_WINDOW_MS=8000

# === Store config ═════════════════════════════════════════════════════════
SUPERBEM_COMPANY_ID=1
STORE_NAME=Super Bem Barato (DEV)
STORE_PHONE=(63) 4141-9318
STORE_ADDRESS=Luzimangues, Porto Nacional - TO
STORE_HOURS=Seg-Sáb 07:00-22:00, Dom 08:00-20:00

# === Alerting (em dev, sem Telegram — deixar vazio pra silenciar) ══════
TELEGRAM_ALERT_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# === Internal ═════════════════════════════════════════════════════════════
# Hostname de serviço docker-compose (não "localhost").
AI_SERVICE_URL=http://ai-service:8000
INTERNAL_API_KEY=dev_internal_key_change_me_openssl_rand_hex_32
MAX_AUDIO_SECONDS=120

# === Groq ═════════════════════════════════════════════════════════════════
GROQ_API_KEY=

# === Shadow mode ═════════════════════════════════════════════════════════
SHADOW_MODE_ENABLED=false
SHADOW_SAMPLE_SIZE=10          # amostra pequena em dev

# === Runtime ══════════════════════════════════════════════════════════════
NODE_ENV=development
PORT=3000
