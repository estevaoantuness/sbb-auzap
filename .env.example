# ════════════════════════════════════════════════════════════════════════════
# SBB-AuZap (Maria v2) — Produção — template de envs
# ════════════════════════════════════════════════════════════════════════════
# Copie para .env e preencha. Em Coolify, seta via API REST (ver scripts/deploy-prod.sh).
# NUNCA commitar .env (já está no .gitignore).
# ════════════════════════════════════════════════════════════════════════════

# === DB ═══════════════════════════════════════════════════════════════════
# sbb-postgres via PgBouncer (session mode, ver D3). Rede docker externa `sbb-db`.
# connection_limit=10 pro Prisma (ver D3 pool sizing).
DATABASE_URL=postgresql://sbb_app:senha@postgres-sbb:6432/sbb?schema=public&connection_limit=10

# === WhatsApp Provider — NÚMERO NOVO DEDICADO (X2) ════════════════════════
# Decisão D7: X2 — chip novo dedicado, preserva o (63) 4141-9318 pra operador humano.
# Decisão D1 (revisada 2026-04-21): BAILEYS default pro MVP; Cloud API fica switchable pra v2.
WHATSAPP_PROVIDER=baileys        # baileys (default, MVP) | cloud_api (v2, requer provisionamento Meta)

# ─── Baileys (MVP) ─────────────────────────────────────────────────────────
# Sessão persistida em volume (configurar no Coolify: /app/sessions).
# QR code exposto em GET /whatsapp/qr após start. Dashboard renderiza.
BAILEYS_SESSIONS_PATH=/app/sessions

# ─── Cloud API (só se WHATSAPP_PROVIDER=cloud_api) ──────────────────────────
WABA_PHONE_NUMBER_ID=          # da Meta Business Manager (Phone Numbers → ID)
WABA_BUSINESS_ACCOUNT_ID=
WABA_ACCESS_TOKEN=             # system user permanent token (não expira)
WABA_APP_SECRET=               # pra validar X-Hub-Signature-256 (Meta app settings)
WABA_VERIFY_TOKEN=             # gerar: openssl rand -hex 16

# === OpenAI ═══════════════════════════════════════════════════════════════
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MODEL_SUMMARY=gpt-5.4-mini
OPENAI_MODEL_JUDGE=gpt-5.4     # só pro shadow mode (juiz LLM)
OPENAI_DAILY_BUDGET_USD=10     # hard cutoff; ao atingir, fallback degradante
HISTORY_SUMMARY_ENABLED=true

# === Queue (pg-boss) ══════════════════════════════════════════════════════
PGBOSS_POOL_MAX=5              # pool separado pra LISTEN/NOTIFY (ver D3)
INBOUND_CONCURRENCY=10         # mensagens processadas em paralelo
COALESCING_WINDOW_MS=8000      # janela pra agrupar msgs do mesmo lead

# === Store config (Super Bem Barato — single-tenant) ═════════════════════
SUPERBEM_COMPANY_ID=1
STORE_NAME=Super Bem Barato
STORE_PHONE=(63) 4141-9318
STORE_ADDRESS=Luzimangues, Porto Nacional - TO
STORE_HOURS=Seg-Sáb 07:00-22:00, Dom 08:00-20:00

# === Alerting (Telegram) ══════════════════════════════════════════════════
TELEGRAM_ALERT_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# === Internal (auth entre api-node ↔ ai-service) ═════════════════════════
AI_SERVICE_URL=http://sbb-auzap-ai:8000
INTERNAL_API_KEY=              # gerar: openssl rand -hex 32
MAX_AUDIO_SECONDS=120          # rejeita áudios > 2min

# === Groq (transcrição de áudio — opcional) ═══════════════════════════════
GROQ_API_KEY=

# === Shadow mode (48h pré-cutover) ═══════════════════════════════════════
SHADOW_MODE_ENABLED=false
SHADOW_SAMPLE_SIZE=100         # min. 100 conversas no replay

# === Runtime ══════════════════════════════════════════════════════════════
NODE_ENV=production
PORT=3000
